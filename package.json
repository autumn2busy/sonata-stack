{
  "name": "sonata-stack",
  "version": "1.0.0",
  "description": "FlyNerd Tech — AI Agent Orchestration Server",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "check:statuses": "node scripts/check-status-literals.mjs",
    "build": "node scripts/check-status-literals.mjs && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "check:runtime-logs": "sh -c 'if rg -n \"console\\\\.log\" src/index.ts src/lib src/agents; then echo \"❌ runtime console.log detected in MCP server directories\"; exit 1; else echo \"✅ no runtime console.log in MCP server directories\"; fi'"
  },
  "keywords": [
    "mcp",
    "ai",
    "agents",
    "orchestration"
  ],
  "author": "FlyNerd Tech",
  "license": "PRIVATE",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@supabase/supabase-js": "^2.100.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.40.0",
    "stripe": "^22.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
